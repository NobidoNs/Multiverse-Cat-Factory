    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GetLightingInformation_float",
    "m_FunctionSource": "48017d793f62f9e48900c4835ad0762c",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "{\n    Direction = float3(0, -1, 0);\n    Color = float3(1, 1, 1);\n    Attenuation = 1;\n    \n    #ifdef SHADERGRAPH_PREVIEW\n        Direction = float3(-0.5, 0.5, -0.5);\n        Attenuation = 0.4;\n    #else\n        Light light = GetMainLight();\n        Direction = light.direction;\n        Color = light.color;\n        Attenuation = light.distanceAttenuation;\n    #endif\n}"
}

